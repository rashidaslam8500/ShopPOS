<Application x:Class="ShopPOS.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ShopPOS.WPF.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:CategoryIsSelectedConverter x:Key="CategoryIsSelectedConverter"/>
            <conv:PaymentMethodDisplayConverter x:Key="PaymentMethodDisplayConverter"/>
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <conv:NullableDecimalConverter x:Key="NullableDecimalConverter"/>
            <conv:BoolToStyleConverter x:Key="CategoryChipStyleConverter"
                                       ActiveStyle="{StaticResource CategoryChipActiveStyle}"
                                       InactiveStyle="{StaticResource CategoryChipStyle}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
