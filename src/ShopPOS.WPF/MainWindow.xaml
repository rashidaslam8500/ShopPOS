<Window x:Class="ShopPOS.WPF.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:vm="clr-namespace:ShopPOS.WPF.ViewModels"

        xmlns:views="clr-namespace:ShopPOS.WPF.Views"

        xmlns:controls="clr-namespace:ShopPOS.WPF.Controls"

        Title="KitchenMart.pk POS"

        MinHeight="650"

        MinWidth="1024"

        WindowStartupLocation="CenterScreen"

        WindowState="Maximized">

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="Auto" MinWidth="240"/>

            <ColumnDefinition Width="*" MinWidth="480"/>

        </Grid.ColumnDefinitions>



        <Border Grid.Column="0"

                Background="White"

                BorderBrush="{StaticResource PrimaryBrush}"

                BorderThickness="0,0,2,0">

            <DockPanel Margin="24,20" LastChildFill="True">

                <controls:BrandHeader DockPanel.Dock="Top"

                                      Compact="True"

                                      Margin="0,0,0,16"/>



                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">

                    <TextBlock Text="{Binding UserDisplay}"

                               Foreground="{StaticResource PrimaryBrush}"

                               FontSize="16"

                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding RoleLabel}"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"/>

                </StackPanel>



                <StackPanel DockPanel.Dock="Bottom">

                    <TextBlock Text="{Binding ClockText}"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               Margin="0,0,0,12"

                               TextWrapping="Wrap"/>

                    <Button Content="Sign Out"

                            Style="{StaticResource NavButtonStyle}"

                            Command="{Binding LogoutCommand}"

                            HorizontalAlignment="Stretch"/>

                </StackPanel>



                <Button DockPanel.Dock="Bottom"

                        Content="⚙  Settings"

                        Style="{StaticResource NavButtonStyle}"

                        Command="{Binding NavigateSettingsCommand}"

                        Margin="0,4,0,12"

                        HorizontalAlignment="Stretch"

                        Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>



                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Modules"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="13"

                               FontWeight="SemiBold"

                               Margin="0,0,0,8"/>

                    <Button Content="🛒  Billing" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCheckoutCommand}" Margin="0,4" HorizontalAlignment="Stretch"/>

                    <Button Content="↩  Returns" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateReturnsCommand}" Margin="0,4" HorizontalAlignment="Stretch"/>

                    <Button Content="📦  Inventory" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateProductsCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="📋  Sales Report" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateSalesCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="📊  Dashboard" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateDashboardCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="🔍  Audit Logs" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateAuditCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="🗑  Trash Bin" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateTrashCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="👷  Staff &amp; Expenses" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateStaffExpensesCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="📒  Vendor Ledger" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateVendorKhataCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Content="💳  Owner Expenses" Style="{StaticResource NavButtonStyle}" Command="{Binding OpenOwnerExpensesCommand}" Margin="0,4" HorizontalAlignment="Stretch"

                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}"/>

                </StackPanel>

            </DockPanel>

        </Border>



        <Grid Grid.Column="1">

            <TabControl Style="{StaticResource ChromeTabControlStyle}"

                        ItemsSource="{Binding Tabs}"

                        SelectedItem="{Binding SelectedTab, Mode=TwoWay}"

                        Visibility="{Binding HasOpenTabs, Converter={StaticResource BoolToVisibilityConverter}}">

                <TabControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TabPageViewModel}">
                        <StackPanel Orientation="Horizontal"
                                    Margin="2,2,6,2"
                                    SnapsToDevicePixels="True">
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       Margin="12,8,6,8"
                                       MaxWidth="200"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="14"/>
                            <Button Content="&#x2715;"
                                    Style="{StaticResource ChromeTabCloseButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    MinWidth="24"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding CloseTabCommand}"
                                    ToolTip="Close tab"
                                    PreviewMouseLeftButtonDown="TabCloseButton_PreviewMouseLeftButtonDown"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>

                    <DataTemplate DataType="{x:Type vm:TabPageViewModel}">

                        <views:TabContentHost/>

                    </DataTemplate>

                </TabControl.ContentTemplate>

            </TabControl>



            <Border Background="{StaticResource BgElevatedBrush}"

                    Visibility="{Binding HasOpenTabs, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">

                <StackPanel VerticalAlignment="Center"

                            HorizontalAlignment="Center"

                            MaxWidth="420">

                    <TextBlock Text="No tabs open"

                               FontSize="24"

                               FontWeight="Bold"

                               Foreground="{StaticResource PrimaryBrush}"

                               HorizontalAlignment="Center"

                               Margin="0,0,0,8"/>

                    <TextBlock Text="Choose a module from the sidebar to open it in a new workspace tab. Each tab keeps its own data and can be closed independently."

                               TextWrapping="Wrap"

                               TextAlignment="Center"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="16"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>

