<UserControl x:Class="ShopPOS.WPF.Controls.BrandHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             HorizontalContentAlignment="Stretch">
    <Grid>
        <!-- Full-width horizontal layout (login + main header bar) -->
        <Grid x:Name="HorizontalLayout"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="LogoImage"
                   Grid.Column="0"
                   MaxHeight="50"
                   Stretch="Uniform"
                   Margin="0,0,12,0"
                   VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch">
                <TextBlock x:Name="TitleText"
                           Text="Bhai Gee Crockery Store — KitchenMart.pk"
                           FontSize="18"
                           FontWeight="Bold"
                           TextWrapping="NoWrap"
                           TextTrimming="None"
                           HorizontalAlignment="Stretch"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock x:Name="SubtitleText"
                           Text="Karkhana Bazar, Sargodha | 03006027106"
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextTrimming="None"
                           HorizontalAlignment="Stretch"
                           Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Compact vertical layout (narrow sidebar) -->
        <StackPanel x:Name="CompactLayout"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
            <Image x:Name="CompactLogoImage"
                   MaxHeight="44"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>
            <TextBlock Text="KitchenMart.pk"
                       FontSize="16"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Karkhana Bazar, Sargodha"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
