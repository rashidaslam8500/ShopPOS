<Window x:Class="ShopPOS.WPF.Windows.LoginWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:controls="clr-namespace:ShopPOS.WPF.Controls"

        Title="KitchenMart.pk — Login"

        WindowState="Maximized"

        WindowStyle="None"

        WindowStartupLocation="CenterScreen"

        ResizeMode="CanResize"

        Background="White">

    <Grid>

        <Border HorizontalAlignment="Center"

                VerticalAlignment="Center"

                Background="White"

                CornerRadius="10"

                BorderBrush="{StaticResource PrimaryBrush}"

                BorderThickness="1"

                Padding="44,40"

                MinWidth="620"

                MaxWidth="960"

                Effect="{StaticResource PremiumShadowEffect}">

            <StackPanel HorizontalAlignment="Stretch">

                <controls:BrandHeader HorizontalAlignment="Stretch"

                                      Margin="0,0,0,28"/>



                <TextBlock Text="USERNAME"

                           Foreground="{StaticResource TextMutedBrush}"

                           FontSize="14"

                           FontWeight="SemiBold"/>

                <TextBox x:Name="UsernameBox"

                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"

                         Margin="0,4,0,12"

                         Padding="12,10"

                         FontSize="16"

                         HorizontalAlignment="Stretch"

                         KeyDown="UsernameBox_KeyDown"/>



                <TextBlock Text="PASSWORD"

                           Foreground="{StaticResource TextMutedBrush}"

                           FontSize="14"

                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="PasswordBox"

                             Margin="0,4,0,4"

                             Padding="12,10"

                             FontSize="16"

                             HorizontalAlignment="Stretch"

                             KeyDown="PasswordBox_KeyDown"/>



                <TextBlock HorizontalAlignment="Right" Margin="0,0,0,8">

                    <Hyperlink Click="ForgotPassword_Click" Foreground="{StaticResource PrimaryBrush}">

                        Forgot Password?

                    </Hyperlink>

                </TextBlock>



                <TextBlock Text="{Binding ErrorMessage}"

                           Foreground="{StaticResource TextBrush}"

                           FontWeight="SemiBold"

                           TextWrapping="Wrap"

                           TextTrimming="None"

                           Margin="0,0,0,8"

                           FontSize="15"

                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>



                <Button Content="Sign In"

                        Style="{StaticResource PrimaryButtonStyle}"

                        Foreground="White"

                        FontSize="17"

                        Padding="14"

                        Margin="0,8,0,0"

                        HorizontalAlignment="Stretch"

                        Click="SignIn_Click"

                        IsDefault="True"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>

