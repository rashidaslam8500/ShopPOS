<Window x:Class="ShopPOS.WPF.Windows.VendorProfileUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Vendor Profile"
        Width="520"
        Height="460"
        MinWidth="480"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White">
    <DockPanel Margin="24">
        <Border DockPanel.Dock="Bottom"
                Padding="0,16,0,0"
                BorderBrush="{StaticResource PrimaryBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        MinWidth="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource NavButtonStyle}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
                <Button Content="Save Changes"
                        MinWidth="130"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="4,0,4,8"
                    Background="White"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PremiumShadowEffect}">
                <StackPanel Margin="24" MinWidth="400">
                    <TextBlock Text="Update Vendor Profile"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Update vendor name, phone number, and address."
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,20"/>

                    <TextBlock Text="Vendor Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding VendorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Phone Number" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Address" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="72"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
