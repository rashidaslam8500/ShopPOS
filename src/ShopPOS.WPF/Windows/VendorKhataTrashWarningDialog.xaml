<Window x:Class="ShopPOS.WPF.Windows.VendorKhataTrashWarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move to Trash"
        MinWidth="480"
        MinHeight="220"
        Width="520"
        Height="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White">
    <Border Margin="28,28,28,32"
            Padding="28,28,28,32"
            Background="White"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource PremiumShadowEffect}">
        <Grid MinWidth="420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Warning"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1"
                       Text="Warning: You are moving this ledger entry to the Trash Bin. This action will modify the vendor's ledger balance. Total Dues and Remaining Balance will be adjusted automatically. Do you wish to proceed?"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Foreground="{StaticResource TextBrush}"
                       LineHeight="24"
                       Margin="0,0,0,24"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        MinWidth="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource NavButtonStyle}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
                <Button Content="Yes, Move to Trash"
                        MinWidth="160"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Confirm_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
