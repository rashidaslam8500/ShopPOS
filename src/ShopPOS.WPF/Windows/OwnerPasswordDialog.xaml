<Window x:Class="ShopPOS.WPF.Windows.OwnerPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Owner Authorization Required"
        MinWidth="460"
        MinHeight="320"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White">
        <Border Margin="28,28,28,32"
            Padding="28,28,28,32"
            Background="White"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource PremiumShadowEffect}">
        <Grid MinWidth="380">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="TitleTextBlock"
                           Text="Permanent Delete Authorization"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="PromptTextBlock"
                           Text="Enter the owner account password to permanently purge selected invoices."
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,24"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Owner Password"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="15"/>
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,5,0,15"
                             Padding="10,8"
                             FontSize="16"
                             KeyDown="PasswordBox_KeyDown"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,20">
                <Button Content="Cancel"
                        MinWidth="110"
                        Margin="0,0,10,0"
                        HorizontalContentAlignment="Center"
                        Style="{StaticResource NavButtonStyle}"
                        Click="Cancel_Click"/>
                <Button x:Name="ConfirmButton" Content="Confirm Delete"
                        MinWidth="140"
                        HorizontalContentAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Confirm_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
