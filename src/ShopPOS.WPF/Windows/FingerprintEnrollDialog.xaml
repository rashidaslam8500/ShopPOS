<Window x:Class="ShopPOS.WPF.Windows.FingerprintEnrollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register Thumbprint"
        Width="420"
        MinHeight="260"
        Height="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White">
    <Border Margin="28"
            Padding="28"
            Background="White"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource PremiumShadowEffect}">
        <StackPanel>
            <TextBlock Text="Biometric Enrollment"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,12"/>
            <TextBlock x:Name="StatusText"
                       Text="Please place thumb on the scanner..."
                       TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,16"/>
            <ProgressBar x:Name="Spinner"
                         IsIndeterminate="True"
                         Height="6"
                         Margin="0,0,0,20"/>
            <Button Content="Cancel"
                    HorizontalAlignment="Right"
                    MinWidth="100"
                    Style="{StaticResource NavButtonStyle}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Border>
</Window>
