<Window x:Class="ShopPOS.WPF.Windows.VendorKhataEntryEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Ledger Entry"
        MinWidth="520"
        MinHeight="480"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="White">
    <Border Margin="28,28,28,32"
            Padding="28,28,28,32"
            Background="White"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource PremiumShadowEffect}">
        <Grid MinWidth="440">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Edit / Update Entry"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="1">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Date" Foreground="{StaticResource TextMutedBrush}"/>
                        <DatePicker x:Name="DatePicker" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Invoice / Bill Number" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="InvoiceBox" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Total Bill (Rs.)" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TotalBillBox" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cash Paid (Rs.)" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="CashPaidBox" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Payment Mode" Foreground="{StaticResource TextMutedBrush}"/>
                <ComboBox x:Name="PaymentModeBox" Margin="0,6,0,12"/>
                <TextBlock Text="Description" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBox x:Name="NotesBox" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancel"
                        MinWidth="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource NavButtonStyle}"
                        Click="Cancel_Click"
                        IsCancel="True"/>
                <Button Content="Save Correction"
                        MinWidth="140"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
