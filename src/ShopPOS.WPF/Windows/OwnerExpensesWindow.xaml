<Window x:Class="ShopPOS.WPF.Windows.OwnerExpensesWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Owner Personal Expenses"

        Width="1000"

        Height="720"

        MinHeight="620"

        MinWidth="900"

        WindowStartupLocation="CenterScreen"

        WindowStyle="SingleBorderWindow"

        ResizeMode="CanResizeWithGrip"

        Background="{StaticResource BgElevatedBrush}">

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Margin="8,8,8,16">

            <TextBlock Text="Owner Personal Expenses" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>

            <TextBlock Text="Private expense log with full memory details — searchable history"

                       Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

        </StackPanel>



        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,12,8,8">

            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"

                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>

            <Button Content="Close" Width="100" Style="{StaticResource NavButtonStyle}" Click="Close_Click"/>

        </StackPanel>



        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="8">

                <Border Style="{StaticResource SettingsCardBorder}" Margin="0,0,0,16">

                    <StackPanel>

                        <TextBlock Text="New Expense" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="16"/>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="16"/>

                                <ColumnDefinition Width="*"/>

                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="Date" Foreground="{StaticResource TextMutedBrush}"/>

                                <DatePicker SelectedDate="{Binding ExpenseDate}" Margin="0,6,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Column="2">

                                <TextBlock Text="Amount (Rs.)" Foreground="{StaticResource TextMutedBrush}"/>

                                <TextBox Text="{Binding ExpenseAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Column="4">

                                <TextBlock Text="Category" Foreground="{StaticResource TextMutedBrush}"/>

                                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Margin="0,6,0,0"/>

                            </StackPanel>

                        </Grid>

                        <TextBlock Text="Description (full memory detail)" Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,4"/>

                        <TextBox Text="{Binding ExpenseDescription, UpdateSourceTrigger=PropertyChanged}"

                                 MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                        <Button Content="Save Expense" Style="{StaticResource PrimaryButtonStyle}"

                                HorizontalAlignment="Left" Command="{Binding SaveCommand}"/>

                    </StackPanel>

                </Border>



                <Border Style="{StaticResource SettingsCardBorder}">

                    <DockPanel MinHeight="280">

                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="16"/>

                                <ColumnDefinition Width="140"/>

                                <ColumnDefinition Width="16"/>

                                <ColumnDefinition Width="140"/>

                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="Search" Foreground="{StaticResource TextMutedBrush}"/>

                                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Column="2">

                                <TextBlock Text="From" Foreground="{StaticResource TextMutedBrush}"/>

                                <DatePicker SelectedDate="{Binding FilterFrom}" Margin="0,6,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Column="4">

                                <TextBlock Text="To" Foreground="{StaticResource TextMutedBrush}"/>

                                <DatePicker SelectedDate="{Binding FilterTo}" Margin="0,6,0,0"/>

                            </StackPanel>

                        </Grid>

                        <DataGrid ItemsSource="{Binding Items}" MinHeight="220">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="110"/>

                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110"/>

                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=Rs. {0:N0}}" Width="120"/>

                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="160"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </DockPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </DockPanel>

</Window>

