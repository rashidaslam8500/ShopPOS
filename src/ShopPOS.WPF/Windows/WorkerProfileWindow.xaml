<Window x:Class="ShopPOS.WPF.Windows.WorkerProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Worker Profile"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{StaticResource BgElevatedBrush}">
    <Border Margin="24" Style="{StaticResource ElevatedCardBorder}" Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{Binding WorkerName}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="15">
                    <Run Text="{Binding WorkerRole, Mode=OneWay}"/>
                    <Run Text="  •  "/>
                    <Run Text="{Binding WorkerPhone, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Year" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ProfileYear, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <TextBlock Text="Month" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,0"/>
                    <TextBox Text="{Binding ProfileMonth, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                </StackPanel>
                <TextBlock Grid.Column="3" Text="{Binding MonthSummaryText}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                <Button Grid.Column="4"
                        Content="Print Employee Report (PDF)"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="14,8"
                        Command="{Binding PrintEmployeeReportPdfCommand}"/>
            </Grid>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <TabItem Header="Salary &amp; Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <TextBlock Text="{Binding SalarySheetText}" FontSize="16" LineHeight="28"
                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <Button Content="Process Monthly Salary (Settle Advances)"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ProcessSalaryCommand}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Daily Cash Ledger">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Date" Foreground="{StaticResource TextMutedBrush}"/>
                                <DatePicker SelectedDate="{Binding DailyCashDate}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Amount (Rs.)" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DailyCashAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Notes" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Text="{Binding DailyCashNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button Grid.Row="1" Content="Add Daily Cash Entry" Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Command="{Binding AddDailyCashCommand}"/>
                        <DataGrid Grid.Row="2" ItemsSource="{Binding DailyCashEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto" MinWidth="110"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="120"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Advance Payments">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Date" Foreground="{StaticResource TextMutedBrush}"/>
                                <DatePicker SelectedDate="{Binding AdvanceDate}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Advance (Rs.)" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Text="{Binding AdvanceAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Notes" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Text="{Binding AdvanceNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Record Advance" Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left" Command="{Binding AddAdvanceCommand}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding AdvanceEntries}" Margin="0,12,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto" MinWidth="110"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="120"/>
                                <DataGridTextColumn Header="Settled" Binding="{Binding IsSettled}" Width="Auto" MinWidth="80"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Attendance &amp; Overtime">
                    <DataGrid ItemsSource="{Binding AttendanceEntries}" Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto" MinWidth="110"/>
                            <DataGridTextColumn Header="Time In" Binding="{Binding TimeIn, StringFormat=hh\\:mm}" Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="Time Out" Binding="{Binding TimeToLeave, StringFormat=hh\\:mm}" Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="OT Hours" Binding="{Binding OvertimeHours, StringFormat=N1}" Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Leave Register">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Leave Date" Foreground="{StaticResource TextMutedBrush}"/>
                                <DatePicker SelectedDate="{Binding LeaveDate}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Leave Type" Foreground="{StaticResource TextMutedBrush}"/>
                                <ComboBox ItemsSource="{Binding LeaveTypes}" SelectedItem="{Binding SelectedLeaveType}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Reason" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Text="{Binding LeaveReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                                <CheckBox Content="Paid Leave" IsChecked="{Binding LeaveIsPaid}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Log Leave" Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left" Command="{Binding AddLeaveCommand}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding LeaveEntries}" Margin="0,12,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto" MinWidth="110"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding LeaveType}" Width="Auto" MinWidth="100"/>
                                <DataGridTextColumn Header="Paid" Binding="{Binding IsPaid}" Width="Auto" MinWidth="70"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Check-Out / Leave Shift">
                    <StackPanel Margin="8">
                        <TextBlock Text="Workers still checked in today — confirm Time Out for safe exit"
                                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding CheckedInWorkers}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Worker" Binding="{Binding Name}" Width="Auto"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="Auto" MinWidth="140"/>
                                <DataGridTemplateColumn Header="Action" Width="*" MinWidth="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Check Out"
                                                    Style="{StaticResource GridActionButtonStyle}"
                                                    Command="{Binding DataContext.CheckOutWorkerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                <Button Content="Close" Width="100" Style="{StaticResource NavButtonStyle}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
