<Window x:Class="ShopPOS.WPF.Windows.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product" Height="520" Width="500"
        MinHeight="480"
        MinWidth="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{StaticResource BgBrush}">
    <Border Margin="28"
            Style="{StaticResource ElevatedCardBorder}"
            Padding="28,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Product Details" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameBox" Margin="0,0,0,12"/>
                    <TextBlock Text="Category" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CategoryBox" Margin="0,0,0,12"/>
                    <TextBlock Text="Description (optional)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DescriptionBox" Margin="0,0,0,12" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Price" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="PriceBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Stock" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="StockBox"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Barcode (scan or auto-generate)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BarcodeBox" KeyDown="BarcodeBox_KeyDown"/>
                        <Button Grid.Column="1" Content="Auto-Generate Barcode" Margin="8,0,0,0"
                                Style="{StaticResource NavButtonStyle}" Click="AutoGenerateBarcode_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Width="100" Margin="0,0,8,0" Style="{StaticResource NavButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Save" Width="100" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
