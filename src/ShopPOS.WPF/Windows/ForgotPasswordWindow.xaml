<Window x:Class="ShopPOS.WPF.Windows.ForgotPasswordWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Password Recovery — Security Questions"

        MinWidth="520"

        MinHeight="560"

        Width="560"

        Height="620"

        WindowStartupLocation="CenterOwner"

        WindowStyle="SingleBorderWindow"

        ResizeMode="CanResize"

        Background="White">

    <Border Margin="28" Padding="28" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="10">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock Text="Reset Password"

                           FontSize="22"

                           FontWeight="Bold"

                           Foreground="{StaticResource PrimaryBrush}"

                           Margin="0,0,0,8"/>

                <TextBlock Text="Enter your username, answer your security questions, then choose a new password."

                           TextWrapping="Wrap"

                           Foreground="{StaticResource TextMutedBrush}"

                           Margin="0,0,0,20"/>



                <TextBlock Text="Username" Foreground="{StaticResource TextMutedBrush}"/>

                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"

                         Margin="0,4,0,12" Padding="10,8" FontSize="16"/>

                <Button Content="Load Security Questions"

                        Style="{StaticResource NavButtonStyle}"

                        HorizontalAlignment="Left"

                        Margin="0,0,0,16"

                        Command="{Binding LoadQuestionsCommand}"/>



                <StackPanel Visibility="{Binding QuestionsLoaded, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="{Binding Question1}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <TextBox x:Name="Answer1Box" Margin="0,0,0,12" Padding="10,8" FontSize="16"/>



                    <TextBlock Text="{Binding Question2}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <TextBox x:Name="Answer2Box" Margin="0,0,0,12" Padding="10,8" FontSize="16"/>



                    <TextBlock Text="New Password" Foreground="{StaticResource TextMutedBrush}"/>

                    <PasswordBox x:Name="NewPasswordBox" Margin="0,4,0,12" Padding="10,8" FontSize="16"/>



                    <TextBlock Text="Confirm New Password" Foreground="{StaticResource TextMutedBrush}"/>

                    <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,4,0,16" Padding="10,8" FontSize="16"/>

                </StackPanel>



                <TextBlock Text="{Binding StatusMessage}"

                           Foreground="{StaticResource TextBrush}"

                           TextWrapping="Wrap"

                           Margin="0,0,0,12"

                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"/>



                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="Cancel" MinWidth="100" Margin="0,0,10,0"

                            Style="{StaticResource NavButtonStyle}" Click="Cancel_Click"/>

                    <Button Content="Reset Password" MinWidth="140"

                            Style="{StaticResource PrimaryButtonStyle}"

                            Click="Reset_Click"

                            IsEnabled="{Binding QuestionsLoaded}"/>

                </StackPanel>

            </StackPanel>

        </ScrollViewer>

    </Border>

</Window>

