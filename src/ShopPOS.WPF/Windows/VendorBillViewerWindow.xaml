<Window x:Class="ShopPOS.WPF.Windows.VendorBillViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Bill Attachment"
        MinWidth="640"
        MinHeight="480"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{StaticResource BgElevatedBrush}">
    <Border Margin="24"
            Style="{StaticResource ElevatedCardBorder}"
            Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Bill Attachment"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          MaxHeight="560">
                <StackPanel x:Name="ContentPanel">
                    <Image x:Name="BillImage"
                           Stretch="Uniform"
                           MaxWidth="900"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel x:Name="PdfPanel"
                                Visibility="Collapsed"
                                Margin="0,24,0,0">
                        <TextBlock Text="This attachment is a PDF document."
                                   FontSize="16"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <Button Content="Open PDF in Default Application"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Click="OpenPdf_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Content="Close"
                    MinWidth="110"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    Style="{StaticResource NavButtonStyle}"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
