<UserControl x:Class="ShopPOS.WPF.Views.SalesView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">

            <TextBlock Text="Scan printed invoice barcode to open Returns &amp; Amendments instantly"

                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>

            <TextBox x:Name="InvoiceScanBox" Width="320" HorizontalAlignment="Left"

                     Text="{Binding InvoiceScanInput, UpdateSourceTrigger=PropertyChanged}"

                     KeyDown="InvoiceScanBox_KeyDown"

                     Tag="Scan invoice barcode"/>

        </StackPanel>



        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">

            <StackPanel>

                <TextBlock Text="Sales History" FontSize="24" FontWeight="Bold"/>

                <TextBlock Text="View past transactions" Foreground="{StaticResource TextMutedBrush}"/>

            </StackPanel>

            <DatePicker SelectedDate="{Binding FilterDate}" Width="160" HorizontalAlignment="Right"/>

        </DockPanel>



        <DataGrid ItemsSource="{Binding Items}">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Receipt #" Binding="{Binding ReceiptNo}" Width="Auto" MinWidth="100"/>

                <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=g}" Width="Auto" MinWidth="140"/>

                <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="Auto" MinWidth="60"/>

                <DataGridTextColumn Header="Payment" Width="Auto" MinWidth="120">

                    <DataGridTextColumn.Binding>

                        <Binding Path="PaymentMethod" Converter="{StaticResource PaymentMethodDisplayConverter}"/>

                    </DataGridTextColumn.Binding>

                </DataGridTextColumn>

                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="90"/>

                <DataGridTemplateColumn Header="Actions" Width="*" MinWidth="180">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Receipt" Margin="0,0,6,0"
                                        Command="{Binding DataContext.ViewReceiptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Trash"
                                        Command="{Binding DataContext.MoveToTrashCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>

</UserControl>


