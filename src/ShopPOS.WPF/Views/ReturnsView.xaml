<UserControl x:Class="ShopPOS.WPF.Views.ReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Returns &amp; Amendments" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Correct invoice items without overwriting the original receipt. Returns use original invoice rates; additions use current stock prices."
                       Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Scan invoice barcode or enter receipt number" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="ReceiptSearchBox" Width="260"
                         Text="{Binding ReceiptSearch, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="ReceiptSearchBox_KeyDown"
                         Tag="Invoice # e.g. BG20260606-0001"/>
                <Button Content="Load Invoice" Style="{StaticResource PrimaryButtonStyle}" Margin="12,0,0,0" Command="{Binding LoadInvoiceCommand}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="{Binding InvoiceInfo}" Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding NetTotalText}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Return Items (Original Invoice Lines)" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="120">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="Auto" MinWidth="140" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Original Rate" Binding="{Binding OriginalPriceText}" Width="Auto" MinWidth="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQty}" Width="Auto" MinWidth="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="90"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2" Text="Add Items to Invoice" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <DockPanel Grid.Row="3">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Width="260" Text="{Binding ProductSearch, UpdateSourceTrigger=PropertyChanged}" Tag="Search product to add"/>
                    <ListBox ItemsSource="{Binding ProductSuggestions}" Width="260" MaxHeight="120" Margin="12,0,0,0"
                             Visibility="{Binding ProductSuggestions.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" HorizontalContentAlignment="Left"
                                        Command="{Binding DataContext.AddProductToAmendmentsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" Style="{StaticResource NavButtonStyle}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                <DataGrid ItemsSource="{Binding Additions}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="Auto" MinWidth="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Rate" Binding="{Binding UnitPriceText}" Width="Auto" MinWidth="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding AvailableStock}" Width="Auto" MinWidth="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="60"/>
                        <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotalText}" Width="Auto" MinWidth="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="120"/>
                        <DataGridTemplateColumn Header="" Width="*" MinWidth="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove" Style="{StaticResource NavButtonStyle}"
                                            Command="{Binding DataContext.RemoveAdditionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <Button Grid.Row="4" Content="Correct and Proceed" Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Left" Margin="0,16,0,0" Padding="20,12" FontSize="16"
                Command="{Binding CorrectAndProceedCommand}"/>
    </Grid>
</UserControl>
