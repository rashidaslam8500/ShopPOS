<UserControl x:Class="ShopPOS.WPF.Views.CheckoutView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:enums="clr-namespace:ShopPOS.Domain.Enums;assembly=ShopPOS.Domain">

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <StackPanel Grid.Row="0" Margin="0,0,0,12">

            <TextBlock Text="Cash &amp; Carry Billing" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>

            <TextBlock Text="Scan barcode, type item name, or enter reference number — press Enter to feed into the invoice"

                       Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,4,0,0"/>

        </StackPanel>



        <Grid Grid.Row="1" Margin="0,0,0,16">

            <ComboBox x:Name="ItemLookupBox"

                      IsEditable="True"

                      IsTextSearchEnabled="False"

                      StaysOpenOnEdit="True"

                      Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"

                      SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"

                      ItemsSource="{Binding SearchSuggestions}"

                      IsDropDownOpen="{Binding IsDropDownOpen, Mode=TwoWay}"

                      FontSize="17"

                      Padding="14,12"

                      BorderBrush="{StaticResource PrimaryBrush}"

                      BorderThickness="2"

                      PreviewKeyDown="ItemLookupBox_PreviewKeyDown"

                      GotFocus="ItemLookupBox_GotFocus">

                <ComboBox.ItemTemplate>

                    <DataTemplate>

                        <Grid Margin="4,6">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16"/>

                                <TextBlock Text="{Binding ReferenceText}" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">

                                <TextBlock Text="{Binding DetailText}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="15"/>

                                <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Right"/>

                            </StackPanel>

                        </Grid>

                    </DataTemplate>

                </ComboBox.ItemTemplate>

            </ComboBox>

            <TextBlock Text="🔍  Scan barcode, search by name, or type reference number..."

                       IsHitTestVisible="False"

                       Foreground="{StaticResource TextMutedBrush}"

                       FontSize="16"

                       Margin="18,0,0,0"

                       VerticalAlignment="Center">

                <TextBlock.Style>

                    <Style TargetType="TextBlock">

                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding Text, ElementName=ItemLookupBox}" Value="">

                                <Setter Property="Visibility" Value="Visible"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

        </Grid>



        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*" MinWidth="360"/>

                <ColumnDefinition Width="380" MinWidth="320"/>

            </Grid.ColumnDefinitions>



            <Border Grid.Column="0"

                    Style="{StaticResource ElevatedCardBorder}"

                    Padding="12,16"

                    Margin="0,0,16,0">

                <DockPanel>

                    <DockPanel DockPanel.Dock="Top" Margin="4,0,4,12">

                        <TextBlock Text="Active Invoice" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>

                        <Button Content="Clear All" HorizontalAlignment="Right"

                                Style="{StaticResource NavButtonStyle}"

                                Command="{Binding ClearCartCommand}"/>

                    </DockPanel>



                    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}"

                               Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="SemiBold" Margin="4,0,4,8"

                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"/>



                    <DataGrid ItemsSource="{Binding Cart}"

                              AutoGenerateColumns="False"

                              CanUserResizeRows="True"

                              VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="Auto" MinWidth="120">

                                <DataGridTextColumn.ElementStyle>

                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">

                                        <Setter Property="FontSize" Value="15"/>

                                    </Style>

                                </DataGridTextColumn.ElementStyle>

                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Ref / Barcode" Binding="{Binding SkuOrBarcode}" Width="Auto" MinWidth="90">

                                <DataGridTextColumn.ElementStyle>

                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">

                                        <Setter Property="FontSize" Value="13"/>

                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>

                                    </Style>

                                </DataGridTextColumn.ElementStyle>

                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Qty" Width="Auto" MinWidth="118">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <StackPanel Orientation="Horizontal"

                                                    HorizontalAlignment="Center"

                                                    VerticalAlignment="Center"

                                                    Margin="0,4">

                                            <Button Content="−" Width="28" Height="28" Style="{StaticResource CompactIconButtonStyle}"
                                                    Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock Text="{Binding Quantity}" MinWidth="28" TextAlignment="Center"
                                                       VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                                                       Margin="4,0"/>
                                            <Button Content="+" Width="28" Height="28" Style="{StaticResource CompactIconButtonStyle}"
                                                    Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Total" Binding="{Binding LineTotalText}" Width="*" MinWidth="100">

                                <DataGridTextColumn.ElementStyle>

                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">

                                        <Setter Property="FontSize" Value="15"/>

                                        <Setter Property="FontWeight" Value="SemiBold"/>

                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>

                                        <Setter Property="TextAlignment" Value="Right"/>

                                    </Style>

                                </DataGridTextColumn.ElementStyle>

                            </DataGridTextColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </DockPanel>

            </Border>



            <Border Grid.Column="1"
                    Background="{StaticResource BgMutedPanelBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Effect="{StaticResource PremiumShadowEffect}"
                    Padding="14,12"
                    Width="320"
                    MinWidth="300">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Payment"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,12">
                        <Button Content="Cash" Margin="2,0" Height="32"
                                Command="{Binding SetPaymentMethodCommand}" CommandParameter="Cash">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PaymentMethodButtonStyle}">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaymentMethod}" Value="{x:Static enums:PaymentMethod.Cash}">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Card" Margin="2,0" Height="32"
                                Command="{Binding SetPaymentMethodCommand}" CommandParameter="Card">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PaymentMethodButtonStyle}">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaymentMethod}" Value="{x:Static enums:PaymentMethod.Card}">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Wallet" Margin="2,0" Height="32"
                                Command="{Binding SetPaymentMethodCommand}" CommandParameter="MobileWallet">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PaymentMethodButtonStyle}">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaymentMethod}" Value="{x:Static enums:PaymentMethod.MobileWallet}">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </UniformGrid>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <TextBlock Text="Customer Mobile (optional)"
                                   Style="{StaticResource CompactPosSummaryLabelStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CustomerPhoneInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CompactPosFullWidthTextBoxStyle}"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="Customer Email (optional)"
                                   Style="{StaticResource CompactPosSummaryLabelStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CustomerEmailInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CompactPosFullWidthTextBoxStyle}"
                                 Margin="0,0,0,10"/>

                        <Button Content="Complete Sale"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Foreground="White"
                                FontSize="15"
                                Padding="12,8"
                                Height="40"
                                HorizontalAlignment="Stretch"
                                Command="{Binding CompleteSaleCommand}"/>
                    </StackPanel>

                    <Border Background="White"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Subtotal" Style="{StaticResource CompactPosSummaryLabelStyle}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubtotalText}" Style="{StaticResource CompactPosSummaryValueStyle}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Discount (Rs.)" Style="{StaticResource CompactPosSummaryLabelStyle}" Margin="0,0,0,6"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource CompactPosFieldTextBoxStyle}"
                                     Margin="0,0,0,6"
                                     Text="{Binding DiscountAmountInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tax" Style="{StaticResource CompactPosSummaryLabelStyle}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TaxText}" Style="{StaticResource CompactPosSummaryValueStyle}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Total Bill" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalText}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" MinWidth="150" TextAlignment="Right" Margin="0,2,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Amount Received" Style="{StaticResource CompactPosSummaryLabelStyle}" Margin="0,0,0,6"/>
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Style="{StaticResource CompactPosFieldTextBoxStyle}"
                                     Margin="0,0,0,6"
                                     Text="{Binding AmountReceivedInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Change Due" Style="{StaticResource CompactPosSummaryLabelStyle}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ChangeText}" Style="{StaticResource CompactPosSummaryValueStyle}" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

        </Grid>

    </Grid>

</UserControl>

