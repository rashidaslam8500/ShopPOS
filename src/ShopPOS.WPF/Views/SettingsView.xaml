<UserControl x:Class="ShopPOS.WPF.Views.SettingsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             HorizontalAlignment="Stretch">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"

                  VerticalScrollBarVisibility="Auto"

                  HorizontalAlignment="Stretch">

        <StackPanel HorizontalAlignment="Stretch" Margin="0,0,12,24">

            <TextBlock Text="Settings &amp; Customization"

                       FontSize="24"

                       FontWeight="Bold"

                       TextWrapping="Wrap"

                       TextTrimming="None"

                       Margin="0,0,0,8"/>

            <TextBlock Text="Owner-only shop configuration, cloud sync, WhatsApp, email, SMS, receipt metadata, and account security."

                       Foreground="{StaticResource TextMutedBrush}"

                       FontSize="16"

                       TextWrapping="Wrap"

                       TextTrimming="None"

                       Margin="0,0,0,24"/>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Change Password"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Current Password" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <PasswordBox x:Name="OldPasswordBox"

                                 Margin="0,4,0,12"

                                 Padding="10,8"

                                 FontSize="16"

                                 HorizontalAlignment="Stretch"/>

                    <TextBlock Text="New Password" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <PasswordBox x:Name="NewPasswordBox"

                                 Margin="0,4,0,12"

                                 Padding="10,8"

                                 FontSize="16"

                                 HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Confirm New Password" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"

                                 Margin="0,4,0,16"

                                 Padding="10,8"

                                 FontSize="16"

                                 HorizontalAlignment="Stretch"/>

                    <Button Content="Update Password"

                            Style="{StaticResource PrimaryButtonStyle}"

                            HorizontalAlignment="Left"

                            Click="ChangePassword_Click"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"

                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Password Recovery (Security Questions)"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Choose two standard questions and answers. They are used when you click Forgot Password on the login screen."

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Security Question 1" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <ComboBox ItemsSource="{Binding AvailableSecurityQuestions}"

                              SelectedItem="{Binding SecurityQuestion1}"

                              Margin="0,4,0,12" Padding="8,6" FontSize="15"/>

                    <TextBlock Text="Answer 1" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox x:Name="SecurityAnswer1Box"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16"/>

                    <TextBlock Text="Security Question 2" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <ComboBox ItemsSource="{Binding AvailableSecurityQuestions}"

                              SelectedItem="{Binding SecurityQuestion2}"

                              Margin="0,4,0,12" Padding="8,6" FontSize="15"/>

                    <TextBlock Text="Answer 2" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox x:Name="SecurityAnswer2Box"

                             Margin="0,4,0,16" Padding="10,8" FontSize="16"/>

                    <Button Content="Save Security Questions"

                            Style="{StaticResource PrimaryButtonStyle}"

                            HorizontalAlignment="Left"

                            Click="SaveSecurityQuestions_Click"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Shop Metadata (Receipts &amp; Branding)"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Shop Name" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Address" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Phone Number" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Currency Symbol" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding CurrencySymbol, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Tax Rate (%)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Receipt Footer Message" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,0"

                             Padding="10,8"

                             FontSize="16"

                             TextWrapping="Wrap"

                             AcceptsReturn="True"

                             MinHeight="60"

                             HorizontalAlignment="Stretch"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Cloud Sync (Hybrid Dashboard)"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Sync sales, inventory, and customers to your cloud dashboard while keeping local SQL Server as primary."

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <CheckBox Content="Enable Background Cloud Sync"

                              IsChecked="{Binding CloudSyncEnabled}"

                              FontSize="16"

                              Foreground="{StaticResource TextBrush}"

                              Margin="0,0,0,12"/>

                    <TextBlock Text="Cloud Server URL" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding CloudServerUrl, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="API Sync Key" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBlock Text="{Binding CloudApiKeyHint}"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="13"

                               TextWrapping="Wrap"

                               Margin="0,0,0,4"/>

                    <TextBlock Text="Saved — API key is stored securely."

                               Foreground="{StaticResource PrimaryBrush}"

                               FontWeight="SemiBold"

                               FontSize="13"

                               Margin="0,0,0,4">

                        <TextBlock.Style>

                            <Style TargetType="TextBlock">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsCloudApiKeyStored}" Value="True">

                                        <Setter Property="Visibility" Value="Visible"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </TextBlock.Style>

                    </TextBlock>

                    <TextBox Text="{Binding CloudApiKeyInput, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,0,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Shop ID (Cloud Tenant)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding CloudShopId, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Sync Interval (minutes)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding CloudSyncIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="{Binding CloudSyncStatus}"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="14"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <Button Content="Sync Now to Cloud"

                            Style="{StaticResource PrimaryButtonStyle}"

                            HorizontalAlignment="Left"

                            Command="{Binding SyncNowCommand}"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="SMS Marketing Gateway"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Send automated thank-you SMS after checkout when a customer mobile number is provided."

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <CheckBox Content="Enable SMS Marketing"

                              IsChecked="{Binding SmsEnabled}"

                              FontSize="16"

                              Foreground="{StaticResource TextBrush}"

                              Margin="0,0,0,12"/>

                    <TextBlock Text="SMS Gateway Provider" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding SmsProvider, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Gateway API URL (GenericHttp / Twilio base URL)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding SmsGatewayUrl, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="API Username" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding SmsApiUsername, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="API Token / Password" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBlock Text="{Binding SmsApiTokenHint}"

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="13"

                               TextWrapping="Wrap"

                               Margin="0,0,0,4"/>

                    <PasswordBox x:Name="SmsApiTokenBox"

                                 Margin="0,0,0,12"

                                 Padding="10,8"

                                 FontSize="16"

                                 HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Sender ID / Masking" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding SmsSenderId, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12"

                             Padding="10,8"

                             FontSize="16"

                             HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Thank-You Message" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding SmsThankYouMessage, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,0"

                             Padding="10,8"

                             FontSize="16"

                             TextWrapping="Wrap"

                             AcceptsReturn="True"

                             MinHeight="60"

                             HorizontalAlignment="Stretch"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="WhatsApp Business (Cloud API)"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Send automated thank-you WhatsApp after checkout when customer mobile is provided. Uses Meta Cloud API or a custom gateway."

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <CheckBox Content="Enable WhatsApp Thank-You"

                              IsChecked="{Binding WhatsAppEnabled}"

                              FontSize="16"

                              Foreground="{StaticResource TextBrush}"

                              Margin="0,0,0,12"/>

                    <TextBlock Text="Provider (MetaCloud / GenericHttp)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding WhatsAppProvider, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="API URL (optional for MetaCloud)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding WhatsAppApiUrl, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Phone Number ID (Meta Cloud)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding WhatsAppPhoneNumberId, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Access Token" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBlock Text="{Binding WhatsAppApiTokenHint}"

                               Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <PasswordBox x:Name="WhatsAppApiTokenBox"

                                 Margin="0,0,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Thank-You Message" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding WhatsAppThankYouMessage, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,0" Padding="10,8" FontSize="16" TextWrapping="Wrap"

                             AcceptsReturn="True" MinHeight="60" HorizontalAlignment="Stretch"/>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource SettingsCardBorder}"
                    HorizontalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Email Receipts (SMTP)"

                               FontSize="18"

                               FontWeight="SemiBold"

                               Foreground="{StaticResource PrimaryBrush}"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <TextBlock Text="Email receipt and thank-you message after checkout when customer email is provided. Gmail/Outlook app passwords work."

                               Foreground="{StaticResource TextMutedBrush}"

                               FontSize="15"

                               TextWrapping="Wrap"

                               Margin="0,0,0,12"/>

                    <CheckBox Content="Enable Email Thank-You / Receipt"

                              IsChecked="{Binding EmailEnabled}"

                              FontSize="16"

                              Foreground="{StaticResource TextBrush}"

                              Margin="0,0,0,12"/>

                    <TextBlock Text="SMTP Host" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailSmtpHost, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="SMTP Port" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailSmtpPort, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <CheckBox Content="Use SSL/TLS"

                              IsChecked="{Binding EmailUseSsl}"

                              FontSize="16" Margin="0,0,0,12"/>

                    <TextBlock Text="SMTP Username" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailUsername, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="SMTP Password" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBlock Text="{Binding EmailPasswordHint}"

                               Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <PasswordBox x:Name="EmailPasswordBox"

                                 Margin="0,0,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="From Email" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailFromAddress, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="From Name" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailFromName, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,12" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Email Subject" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>

                    <TextBox Text="{Binding EmailThankYouSubject, UpdateSourceTrigger=PropertyChanged}"

                             Margin="0,4,0,0" Padding="10,8" FontSize="16" HorizontalAlignment="Stretch"/>

                </StackPanel>

            </Border>



            <TextBlock Text="{Binding StatusMessage}"

                       Foreground="{StaticResource PrimaryBrush}"

                       FontSize="14"

                       TextWrapping="Wrap"

                       Margin="0,0,0,8"

                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Button Content="Save Shop Settings"

                    Style="{StaticResource PrimaryButtonStyle}"

                    HorizontalAlignment="Left"

                    Margin="0,0,0,24"

                    Click="SaveShopSettings_Click"/>

        </StackPanel>

    </ScrollViewer>

</UserControl>

