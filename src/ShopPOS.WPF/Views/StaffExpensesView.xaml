<UserControl x:Class="ShopPOS.WPF.Views.StaffExpensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toast notification -->
        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="16,14"
                CornerRadius="10"
                Background="{StaticResource PrimaryBrush}"
                Effect="{StaticResource PremiumShadowEffect}"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,24">
                <Grid Margin="0,4,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Staff &amp; Expenses"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Worker management, biometric attendance, and daily cash/expense logging"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="Owner Personal Expenses"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding OpenOwnerExpensesCommand}"
                                Margin="0,0,12,0"/>
                    </StackPanel>
                </Grid>

                <!-- Workers -->
                <Border Style="{StaticResource SettingsCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Worker Management"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Name" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <TextBox Text="{Binding NewWorkerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12"/>
                                <TextBlock Text="Phone" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <TextBox Text="{Binding NewWorkerPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Role" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <TextBox Text="{Binding NewWorkerRole, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12"/>
                                <TextBlock Text="Monthly Salary (Rs.)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <TextBox Text="{Binding NewWorkerSalary, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Register Thumbprint"
                                    Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding RegisterThumbprintCommand}"
                                    Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding FingerprintStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Content="Add New Worker"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Command="{Binding AddWorkerCommand}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardBorder}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Active Staff (double-click to open profile)"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="Print Employee Report (PDF)"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,10"
                                    HorizontalAlignment="Right"
                                    Command="{Binding PrintEmployeeReportPdfCommand}"/>
                        </Grid>
                        <DataGrid x:Name="WorkersGrid"
                                  ItemsSource="{Binding Workers}"
                                  SelectedItem="{Binding SelectedWorker}"
                                  MouseDoubleClick="WorkersGrid_MouseDoubleClick"
                                  MaxHeight="280">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" MinWidth="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="Auto" MinWidth="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="Auto" MinWidth="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Salary" Binding="{Binding MonthlySalary, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Actions" Width="*" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Profile"
                                                        Style="{StaticResource GridActionButtonStyle}"
                                                        Width="65"
                                                        Command="{Binding DataContext.OpenWorkerProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Mark"
                                                        Style="{StaticResource GridActionButtonStyle}"
                                                        Width="60"
                                                        Command="{Binding DataContext.MarkAttendanceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Delete"
                                                        Style="{StaticResource GridActionButtonStyle}"
                                                        Width="75"
                                                        Command="{Binding DataContext.DeleteWorkerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Attendance -->
                <Border Style="{StaticResource SettingsCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Biometric Attendance (Today)"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ScannerStatus}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding TodayAttendance}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Worker" Binding="{Binding Worker.Name}" Width="Auto" MinWidth="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Time In" Binding="{Binding TimeIn, StringFormat=hh\\:mm}" Width="Auto" MinWidth="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Time Out" Binding="{Binding TimeToLeave, StringFormat=hh\\:mm}" Width="Auto" MinWidth="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="OT Hrs" Binding="{Binding OvertimeHours, StringFormat=N1}" Width="Auto" MinWidth="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" MinWidth="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Check-Out / Leave Shift -->
                <Border Style="{StaticResource SettingsCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Check-Out / Leave Shift"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Workers still checked in — confirm Time Out for safe exit"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding CheckedInWorkers}"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Worker" Binding="{Binding Name}" Width="Auto" MinWidth="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="Auto" MinWidth="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Action" Width="*" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Check Out"
                                                    Style="{StaticResource GridActionButtonStyle}"
                                                    Command="{Binding DataContext.CheckOutWorkerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Expenses -->
                <Border Style="{StaticResource SettingsCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Daily Cash Intake &amp; Expenses"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Date" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <DatePicker SelectedDate="{Binding ExpenseDate}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Daily Cash Intake (Rs.)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                                <TextBox Text="{Binding DailyCashIntake, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Total Expense (Rs.)" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                        <TextBox Text="{Binding TotalExpense, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource NullableDecimalConverter}}" Margin="0,6,0,12"/>
                        <TextBlock Text="Expense Description" Foreground="{StaticResource TextMutedBrush}" FontSize="15"/>
                        <TextBox Text="{Binding ExpenseDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,6,0,16"
                                 MinHeight="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                        <Button Content="Save Cash &amp; Expense"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Command="{Binding SaveExpenseCommand}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ElevatedCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Recent Expense Logs"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding ExpenseEntries}"
                                  MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto" MinWidth="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Cash Intake" Binding="{Binding DailyCashIntake, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Expense" Binding="{Binding TotalExpense, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding ExpenseDescription}" Width="*" MinWidth="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
