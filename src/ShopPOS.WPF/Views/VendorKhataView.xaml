<UserControl x:Class="ShopPOS.WPF.Views.VendorKhataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PermanentDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Vendor Ledger"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Manage vendor purchases, payments, bill attachments, and ledger history"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="16"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="240"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SettingsCardBorder}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Vendors" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="Edit Profile"
                                Style="{StaticResource NavButtonStyle}"
                                Padding="12,6"
                                HorizontalAlignment="Right"
                                Command="{Binding UpdateVendorProfileCommand}"/>
                    </Grid>
                    <Border DockPanel.Dock="Bottom" Style="{StaticResource ElevatedCardBorder}" Margin="0,12,0,0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Add Vendor" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Name" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox Text="{Binding NewVendorName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                            <TextBlock Text="Phone" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox Text="{Binding NewVendorPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                            <TextBlock Text="Address" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox Text="{Binding NewVendorAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                            <Button Content="Add Vendor" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddVendorCommand}"/>
                        </StackPanel>
                    </Border>
                    <ListBox ItemsSource="{Binding Vendors}"
                             SelectedItem="{Binding SelectedVendor}"
                             DisplayMemberPath="Name"
                             BorderThickness="0"
                             Background="Transparent"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SettingsCardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                        <Run Text="Ledger — "/>
                        <Run Text="{Binding SelectedVendor.Name, FallbackValue='Select a vendor', TargetNullValue='Select a vendor'}"/>
                    </TextBlock>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,16,0,16">
                        <Border Style="{StaticResource ElevatedCardBorder}" Padding="16,14" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Total Bills (Purchases)" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding TotalDuesText}" FontSize="22" FontWeight="Bold" Foreground="#EF4444" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ElevatedCardBorder}" Padding="16,14" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Total Cash Paid" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding TotalPaidText}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ElevatedCardBorder}" Padding="16,14" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Remaining Balance" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding NetBalanceText}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="New Purchase Entry"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="20,12"
                                FontSize="16"
                                Command="{Binding NewPurchaseEntryCommand}"
                                Margin="0,0,12,0"/>
                        <Button Content="Print Ledger (PDF)"
                                Style="{StaticResource NavButtonStyle}"
                                Padding="20,12"
                                FontSize="15"
                                Command="{Binding PrintLedgerPdfCommand}"
                                Margin="0,0,12,0"/>
                        <Button Content="Edit Entry"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding EditEntryCommand}"
                                Margin="0,0,12,0"/>
                        <Button Content="Move to Trash"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding DeleteEntryCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding KhataLines}"
                              SelectedItem="{Binding SelectedKhataLine}"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:MM/dd/yyyy}}" Width="Auto" MinWidth="100"/>
                            <DataGridTextColumn Header="Invoice / Bill Number" Binding="{Binding InvoiceNumber}" Width="Auto" MinWidth="120"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="Auto" MinWidth="140"/>
                            <DataGridTextColumn Header="Previous Balance" Binding="{Binding PreviousBalance, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="120"/>
                            <DataGridTextColumn Header="Total Bill" Binding="{Binding TotalBill, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="100"/>
                            <DataGridTextColumn Header="Cash Paid" Binding="{Binding CashPaid, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="100"/>
                            <DataGridTextColumn Header="Remaining Balance" Binding="{Binding RunningBalance, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="120"/>
                            <DataGridTemplateColumn Header="View Bill" Width="*" MinWidth="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="👁"
                                                ToolTip="View Bill"
                                                Style="{StaticResource GridActionButtonStyle}"
                                                Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Command="{Binding DataContext.ViewBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="4"
                            Style="{StaticResource ElevatedCardBorder}"
                            Margin="0,16,0,0"
                            Padding="16"
                            Visibility="{Binding IsTrashSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="Vendor Trash"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Delete Permanently"
                                            Style="{StaticResource PermanentDeleteButtonStyle}"
                                            Command="{Binding PermanentDeleteTrashCommand}"
                                            Margin="0,0,12,0"/>
                                    <Button Content="Restore Selected"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding RestoreEntryCommand}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Tick the Select checkboxes to choose entries. Restore returns them to the active ledger. Delete Permanently removes them from the database forever."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding TrashItems}"
                                      SelectedItem="{Binding SelectedTrashItem}"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      AutoGenerateColumns="False"
                                      MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Select"
                                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" MinWidth="70"/>
                                    <DataGridTextColumn Header="Deleted On" Binding="{Binding DeletedAt, StringFormat={}{0:MM/dd/yyyy hh:mm tt}}" Width="Auto" MinWidth="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:MM/dd/yyyy}}" Width="Auto" MinWidth="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Invoice / Bill Number" Binding="{Binding InvoiceNumber}" Width="Auto" MinWidth="110" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Total Bill" Binding="{Binding TotalBill, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Cash Paid" Binding="{Binding CashPaid, StringFormat=Rs. {0:N0}}" Width="Auto" MinWidth="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="120" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
